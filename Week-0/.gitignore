# ======================
# PYTHON
# ======================

# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.env/
env/
.venv/

# Python egg / distribution
*.egg-info/
dist/
build/

# ======================
# JUPYTER NOTEBOOKS
# ======================

# Notebook checkpoints (auto-saved drafts — not needed on GitHub)
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ======================
# DATA FILES
# ======================

# Raw and sensitive data files — never upload to GitHub
data/raw/
*.csv
*.xlsx
*.xls
*.json
*.parquet
*.db
*.sqlite

# ======================
# VS CODE
# ======================

# VS Code workspace settings (personal to your machine)
.vscode/
*.code-workspace

# ======================
# GOOGLE COLAB
# ======================

# Colab runtime files
.config/
drive/

# ======================
# OPERATING SYSTEM
# ======================

# Mac
.DS_Store
.AppleDouble

# Windows
Thumbs.db
desktop.ini
ehthumbs.db

# ======================
# MISCELLANEOUS
# ======================

# Log files
*.log

# Temporary files
*.tmp
*.temp
*.swp
